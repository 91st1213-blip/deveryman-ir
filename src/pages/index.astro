              </thead>
              <tbody>
                {companies.map(c => {
                  const col = COMPANY_COLORS[c.name] || { bg: "#555", accent: "#555" };
                  const unitYoyClass = c.unitYoy >= 0 ? 'yoy-positive' : 'yoy-negative';
                  return (
