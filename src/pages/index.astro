      <div class="summary-tables-grid">
        <!-- 業績ハイライト -->
        <div class="table-container">
          <div class="table-meta">業績ハイライト<span>単位: 億円</span></div>
          <div class="table-wrap">
            <table class="data-table" id="table-highlights">
              <thead>
                <tr>
                  <th>企業名</th>
