  <!-- ─── CARD SCROLL JS ─── -->
  <script>
    const wrapper = document.getElementById('cards-scroll');
    const btnLeft = document.getElementById('btn-left');
    const btnRight = document.getElementById('btn-right');
    if (wrapper && btnLeft && btnRight) {
      btnLeft.onclick = () => wrapper.scrollBy({ left: -230, behavior: 'smooth' });
      btnRight.onclick = () => wrapper.scrollBy({ left: 230, behavior: 'smooth' });
    }
  </script>

