// liveDataでcompanies配列の財務項目を上書き
const mergedCompanies = companies.map(c => {
  const live = liveData.find(l => l.code === c.code);
  if (!live) return c;
  return {
    ...c,
    period:      live.period      ?? c.period,
    announcedAt: live.announcedAt ?? c.announcedAt,
    badge:    live.badge    ?? c.badge,
    revenue:  live.revenue  ?? c.revenue,
    revYoy:   live.revYoy   ?? c.revYoy,
    op:       live.op       ?? c.op,
    margin:   live.margin   ?? c.margin,
