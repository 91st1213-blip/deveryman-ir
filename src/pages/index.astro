const projectStatusMap: Record<string, string> = {
  "完成": "status-complete",
  "進行中": "status-active",
  "着工済": "status-started",
  "計画中": "status-plan",
};

const updatedAt = new Date().toLocaleDateString("ja-JP", { timeZone: "Asia/Tokyo", year: "numeric", month: "long", day: "numeric" });

// Helper functions for Astro template
function getMarginClass(val: number) { 
  return val >= 20 ? 'margin-high' : val >= 15 ? 'margin-mid' : 'margin-low'; 
}
