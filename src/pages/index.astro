---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>大手不動産デベロッパー IR ダッシュボード | deveryman-ir</title>
  <meta name="description" content="三井不動産・三菱地所などの最新決算・再開発情報をまとめて確認" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />

  <style is:global>
    /* === RESET & BASE === */
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    html {
      scroll-behavior: smooth;
    }
    body {
      font-family: 'Noto Sans JP', -apple-system, sans-serif;
      background: linear-gradient(135deg, #0a0f1e 0%, #1a1f3a 100%);
      color: #e8eaf0;
      min-height: 100vh;
      line-height: 1.6;
    }
    a {
      color: inherit;
      text-decoration: none;
    }

    /* === LAYOUT === */
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* === HEADER === */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 15, 30, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: 16px 0;
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-size: 1.25rem;
      font-weight: 900;
      letter-spacing: -0.02em;
      background: linear-gradient(90deg, #60a5fa, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .logo span {
      font-weight: 400;
      opacity: 0.7;
    }
    .nav {
      display: flex;
      gap: 24px;
    }
    .nav a {
      font-size: 0.85rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.6);
      transition: color 0.2s;
    }
    .nav a:hover {
      color: #fff;
    }
    .badge-updated {
      font-size: 0.75rem;
      background: rgba(96, 165, 250, 0.15);
      border: 1px solid rgba(96, 165, 250, 0.3);
      color: #93c5fd;
      padding: 4px 12px;
      border-radius: 20px;
    }

    /* === AD BANNER SLOTS === */
    .ad-banner {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .ad-banner-header {
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      min-height: 90px;
      padding: 8px 0;
    }
    .ad-banner-footer {
      background: rgba(255, 255, 255, 0.03);
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      min-height: 90px;
      padding: 8px 0;
    }
    .ad-placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      max-width: 728px;
      height: 90px;
      border: 1px dashed rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: rgba(255, 255, 255, 0.15);
      font-size: 0.72rem;
      letter-spacing: 0.05em;
      user-select: none;
    }
    .ad-placeholder-icon {
      font-size: 1rem;
      opacity: 0.4;
    }
    .ad-banner img {
      max-width: 728px;
      width: 100%;
      height: auto;
      max-height: 90px;
      object-fit: contain;
      border-radius: 6px;
    }
    .ad-banner a {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* === HERO === */
    .hero {
      padding: 40px 0 24px;
      background: radial-gradient(ellipse at 50% -20%, rgba(96, 165, 250, 0.12) 0%, transparent 70%);
      text-align: center;
    }
    .hero-eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #60a5fa;
      margin-bottom: 12px;
    }
    .hero-title {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 900;
      line-height: 1.2;
      margin-bottom: 12px;
    }
    .hero-title em {
      font-style: normal;
      background: linear-gradient(90deg, #60a5fa, #a78bfa, #f472b6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero-sub {
      font-size: 0.88rem;
      color: rgba(255, 255, 255, 0.5);
      max-width: 480px;
      margin: 0 auto;
    }

    /* === SECTION COMMON === */
    .section {
      padding: 32px 0;
    }
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
      flex-wrap: wrap;
    }
    .section-title-wrap {
      display: flex;
      align-items: baseline;
      gap: 12px;
    }
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
    }
    .section-count {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.4);
    }
    .section-divider {
      border: none;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      margin-bottom: 20px;
    }

    /* === COMPANY CARDS ROW === */
    .cards-row {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .scroll-arrow {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.05);
      color: rgba(255, 255, 255, 0.7);
      border-radius: 12px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      position: relative;
      overflow: hidden;
      z-index: 2;
    }
    .scroll-arrow::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(96, 165, 250, 0.25) 0%, rgba(167, 139, 250, 0.25) 100%);
      opacity: 0;
      transition: opacity 0.3s ease;
      border-radius: 12px;
    }
    .scroll-arrow:hover {
      border-color: rgba(96, 165, 250, 0.5);
      color: #fff;
      transform: scale(1.1);
      box-shadow: 0 0 24px rgba(96, 165, 250, 0.25), 0 4px 16px rgba(0, 0, 0, 0.3);
    }
    .scroll-arrow:hover::before {
      opacity: 1;
    }
    .scroll-arrow:active {
      transform: scale(0.95);
      box-shadow: 0 0 8px rgba(96, 165, 250, 0.15);
    }
    .scroll-arrow svg {
      width: 20px;
      height: 20px;
      position: relative;
      z-index: 1;
      transition: transform 0.2s ease;
    }
    .scroll-arrow:hover svg {
      transform: scale(1.15);
    }
    .scroll-arrow-left {
      margin-right: 14px;
    }
    .scroll-arrow-right {
      margin-left: 14px;
    }
    .cards-scroll-wrapper {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      scroll-behavior: smooth;
      scrollbar-width: none;
      padding: 4px 0 8px;
      flex: 1;
      min-width: 0;
    }
    .cards-scroll-wrapper::-webkit-scrollbar {
      display: none;
    }
    .company-card {
      min-width: 200px;
      max-width: 210px;
      flex-shrink: 0;
      border-radius: 12px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      cursor: pointer;
    }
    .company-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
      border-color: rgba(255, 255, 255, 0.15);
    }
    .card-header {
      padding: 10px 12px 8px;
      position: relative;
    }
    .card-header-bg {
      position: absolute;
      inset: 0;
      opacity: 0.9;
    }
    .card-header-content {
      position: relative;
      z-index: 1;
    }
    .card-top-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 4px;
    }
    .company-name {
      font-size: 0.88rem;
      font-weight: 700;
      color: #fff;
    }
    .sec-code {
      font-size: 0.7rem;
      color: rgba(255, 255, 255, 0.6);
    }
    .card-body {
      padding: 10px 12px 12px;
    }
    .fiscal-badge {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      background: rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.8);
      padding: 2px 8px;
      border-radius: 20px;
      white-space: nowrap;
      width: fit-content;
      margin-bottom: 8px;
    }
    .metrics-mini {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 10px;
    }
    .metric-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .metric-label {
      font-size: 0.65rem;
      color: rgba(255, 255, 255, 0.45);
    }
    .metric-value {
      font-size: 0.8rem;
      font-weight: 700;
      color: #e8eaf0;
    }
    .margin-bar-wrap {
      margin-bottom: 10px;
    }
    .margin-bar-label {
      display: flex;
      justify-content: space-between;
      font-size: 0.65rem;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 4px;
    }
    .margin-bar-track {
      height: 3px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 99px;
      overflow: hidden;
    }
    .margin-bar-fill {
      height: 100%;
      border-radius: 99px;
      background: linear-gradient(90deg, #34d399, #10b981);
      transition: width 0.8s ease;
    }
    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 10px;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }
    .stock-info {
      font-size: 0.7rem;
      color: rgba(255, 255, 255, 0.5);
    }
    .stock-info strong {
      color: #e8eaf0;
      font-weight: 600;
    }
    .ir-link {
      font-size: 0.68rem;
      font-weight: 600;
      color: #93c5fd;
      display: flex;
      align-items: center;
      gap: 3px;
      background: rgba(96, 165, 250, 0.1);
      padding: 3px 8px;
      border-radius: 6px;
      transition: background 0.2s;
    }
    .ir-link:hover {
      background: rgba(96, 165, 250, 0.2);
    }

    /* === FILTER BUTTONS === */
    .filter-group {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: none;
      padding-bottom: 2px;
    }
    .filter-group::-webkit-scrollbar {
      display: none;
    }
    .filter-btn {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.6);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.25s ease;
    }
    .filter-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
    }
    .filter-btn.active {
      background: linear-gradient(135deg, rgba(96, 165, 250, 0.3) 0%, rgba(167, 139, 250, 0.3) 100%);
      border-color: rgba(96, 165, 250, 0.5);
      color: #fff;
      box-shadow: 0 0 12px rgba(96, 165, 250, 0.15);
    }

    /* === NEWS TICKER === */
    .news-ticker-section {
      background: rgba(255, 255, 255, 0.02);
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: 24px 0;
    }
    .news-scroll-wrapper {
      height: 440px;
      overflow: hidden;
      position: relative;
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
    }
    .news-scroll-wrapper::before,
    .news-scroll-wrapper::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      height: 48px;
      z-index: 2;
      pointer-events: none;
    }
    .news-scroll-wrapper::before {
      top: 0;
      background: linear-gradient(to bottom, rgba(15, 23, 42, 0.95), transparent);
    }
    .news-scroll-wrapper::after {
      bottom: 0;
      background: linear-gradient(to top, rgba(15, 23, 42, 0.95), transparent);
    }
    .news-ticker-track {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 16px;
    }
    .news-ticker-track:hover {
      animation-play-state: paused !important;
    }
    @keyframes ticker-scroll-vertical {
      0% {
        transform: translateY(0);
      }
      100% {
        transform: translateY(-50%);
      }
    }
    /* === NEWS CARD: ONE-LINE DESIGN === */
    .news-card {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 20px;
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      cursor: pointer;
      transition: all 0.2s ease;
      flex-shrink: 0;
      text-decoration: none;
      color: inherit;
      white-space: nowrap;
      overflow: hidden;
    }
    .news-card:first-child {
      border-radius: 12px 12px 0 0;
    }
    .news-card:last-child {
      border-radius: 0 0 12px 12px;
      border-bottom: none;
    }
    .news-card:hover {
      background: rgba(255, 255, 255, 0.06);
    }
    .news-card-date {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.35);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
      width: 82px;          /* ← 追加 */
      min-width: 82px;      /* ← 追加 */
    }
    .news-category {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      padding: 2px 8px;
      border-radius: 4px;
      white-space: nowrap;
      text-transform: uppercase;
      flex-shrink: 0;
      width: 28px;           /* ← 追加 */
      min-width: 28px;       /* ← 追加 */
      text-align: center;    /* ← 追加 */
    }
    .news-category.IR {
      background: rgba(96, 165, 250, 0.15);
      color: #93c5fd;
    }
    .news-category.PR {
      background: rgba(167, 139, 250, 0.15);
      color: #c4b5fd;
    }
    .news-card-company {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--accent-color, #93c5fd);
      white-space: nowrap;
      flex-shrink: 0;
      width: 110px;          /* ← 追加 */
      min-width: 110px;      /* ← 追加 */
    }
    .news-card-sep {
      color: rgba(255, 255, 255, 0.15);
      flex-shrink: 0;
      font-size: 0.75rem;
    }
    .news-card-title {
      font-size: 0.82rem;
      font-weight: 700;
      color: #e8eaf0;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .news-card-desc {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.38);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      min-width: 0;
    }
    .news-empty {
      padding: 60px 20px;
      text-align: center;
      color: rgba(255, 255, 255, 0.3);
      font-size: 0.85rem;
    }

    /* === SUMMARY TABLE === */
    .table-wrap {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      overflow: hidden;
    }
    .data-table {
      width: 100%;
      border-collapse: collapse;
    }
    .data-table th {
      background: rgba(255, 255, 255, 0.05);
      padding: 10px 14px;
      text-align: right;
      font-size: 0.7rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.45);
      letter-spacing: 0.05em;
      white-space: nowrap;
    }
    .data-table th:first-child {
      text-align: left;
    }
    .data-table td {
      padding: 12px 14px;
      text-align: right;
      font-size: 0.82rem;
      font-weight: 500;
      color: #e8eaf0;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      white-space: nowrap;
    }
    .data-table td:first-child {
      text-align: left;
    }
    .data-table tr:hover td {
      background: rgba(255, 255, 255, 0.03);
    }
    .company-label {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .company-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .yoy-growth {
      font-size: 0.75rem;
      font-weight: 600;
    }
    .yoy-positive {
      color: #34d399;
    }
    .yoy-negative {
      color: #f87171;
    }
    .margin-pill {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 600;
    }
    .margin-high {
      background: rgba(52, 211, 153, 0.15);
      color: #34d399;
    }
    .margin-mid {
      background: rgba(251, 191, 36, 0.15);
      color: #fbbf24;
    }
    .margin-low {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
    }

    /* === PROJECTS TABLE === */
    .project-status {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 20px;
    }
    .status-active {
      background: rgba(52, 211, 153, 0.15);
      color: #34d399;
    }
    .status-plan {
      background: rgba(251, 191, 36, 0.15);
      color: #fbbf24;
    }
    .status-complete {
      background: rgba(148, 163, 184, 0.15);
      color: #94a3b8;
    }
    .status-started {
      background: rgba(96, 165, 250, 0.15);
      color: #93c5fd;
    }

    /* === FOOTER === */
    .footer {
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding: 28px 0;
      margin-top: 40px;
    }
    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .footer-text {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.3);
    }
    .footer-links {
      display: flex;
      gap: 20px;
    }
    .footer-links a {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.3);
    }
    .footer-links a:hover {
      color: rgba(255, 255, 255, 0.6);
    }

    /* === RESPONSIVE === */
    @media (max-width: 768px) {
      .nav {
        display: none;
      }
      .hero-title {
        font-size: 1.4rem;
      }
      .data-table {
        font-size: 0.72rem;
      }
      .data-table th,
      .data-table td {
        padding: 8px 8px;
      }
      .section-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }
      .filter-group {
        align-self: stretch;
      }
      .scroll-arrow {
        width: 36px;
        height: 36px;
        border-radius: 10px;
      }
      .scroll-arrow svg {
        width: 16px;
        height: 16px;
      }
      .scroll-arrow-left {
        margin-right: 8px;
      }
      .scroll-arrow-right {
        margin-left: 8px;
      }
      .news-card {
        padding: 10px 14px;
        gap: 6px;
      }
      .news-card-company {
        font-size: 0.75rem;
      }
      .news-card-title {
        font-size: 0.75rem;
      }
      .news-card-desc {
        font-size: 0.7rem;
      }
      .news-scroll-wrapper {
        height: 380px;
      }
      .ad-placeholder {
        max-width: 320px;
        height: 50px;
      }
      .ad-banner-header,
      .ad-banner-footer {
        min-height: 50px;
      }
      .ad-banner img {
        max-height: 50px;
      }
    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <div class="header-inner">
        <div class="logo">deveryman<span>-ir</span></div>
        <nav class="nav">
          <a href="#companies">企業カード</a>
          <a href="#news">ニュース</a>
          <a href="#summary">決算サマリー</a>
          <a href="#projects">再開発PJ</a>
        </nav>
        <div class="badge-updated">更新: {updatedAt}</div>
      </div>
    </div>
  </header>

  <!-- HEADER AD BANNER -->
  <div class="ad-banner ad-banner-header" id="ad-header">
    <div class="ad-placeholder">
      <span class="ad-placeholder-icon">📢</span>
      AD SPACE — HEADER（728×90）
    </div>
    <!-- To use: replace .ad-placeholder with:
    <a href="https://example.com" target="_blank" rel="noopener sponsored">
      <img src="https://example.com/banner-728x90.png" alt="Ad" width="728" height="90" loading="lazy" />
    </a>
    -->
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">Real Estate Developer IR Dashboard</p>
      <h1 class="hero-title">大手不動産デベロッパー<br /><em>最新IR情報</em></h1>
      <p class="hero-sub">三井・三菱・住友・東建・野村・東急<br />決算データ・再開発プロジェクトを一覧</p>
    </div>
  </section>

  <!-- SECTION 1: Company Cards -->
  <section class="section" id="companies">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">📊 企業カード</h2>
          <span class="section-count">{companies.length}社</span>
        </div>
      </div>
      <hr class="section-divider" />

      <div class="cards-row">
        <button class="scroll-arrow scroll-arrow-left" id="btn-left" aria-label="左へスクロール">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <div class="cards-scroll-wrapper" id="cards-scroll">
          {companies.map((c) => {
            const col = COMPANY_COLORS[c.name] ?? { bg: "#222", accent: "#888", text: "#eee" };
            return (
              <article class="company-card">
                <div class="card-header">
                  <div class="card-header-bg" style={`background: linear-gradient(135deg, ${col.bg} 0%, ${col.accent}55 100%);`} />
                  <div class="card-header-content">
                    <div class="card-top-row">
                      <span class="company-name">{c.name}</span>
                    </div>
                    <span class="sec-code">東証 {c.secCode}</span>
                  </div>
                </div>
                <div class="card-body">
                  <div class="fiscal-badge">{c.period} 決算</div>
                  <div class="metrics-mini">
                    <div class="metric-row">
                      <span class="metric-label">営業収益</span>
                      <span class="metric-value">{(c.revenue / 10000).toFixed(1)}兆円</span>
                    </div>
                    <div class="metric-row">
                      <span class="metric-label">営業利益</span>
                      <span class="metric-value">{c.operatingProfit.toLocaleString()}億円</span>
                    </div>
                  </div>
                  <div class="margin-bar-wrap">
                    <div class="margin-bar-label">
                      <span>利益率</span>
                      <span>{c.profitMargin.toFixed(1)}%</span>
                    </div>
                    <div class="margin-bar-track">
                      <div class="margin-bar-fill" style={`width: ${Math.min(c.profitMargin * 2, 100)}%`} />
                    </div>
                  </div>
                  <div class="card-footer">
                    <span class="stock-info">¥<strong>{c.stockPrice.toLocaleString()}</strong></span>
                    <a class="ir-link" href={c.irLink} target="_blank" rel="noopener">IR ↗</a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        <button class="scroll-arrow scroll-arrow-right" id="btn-right" aria-label="右へスクロール">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- SECTION 2: News (JS-rendered only) -->
  <section class="news-ticker-section" id="news">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">📰 最新ニュース & IRリリース</h2>
          <span class="section-count"></span>
        </div>
        <div class="filter-group" id="news-filter">
          <button class="filter-btn active" data-filter="all">すべて</button>
          <button class="filter-btn" data-filter="三井不動産">三井</button>
          <button class="filter-btn" data-filter="三菱地所">三菱</button>
          <button class="filter-btn" data-filter="住友不動産">住友</button>
          <button class="filter-btn" data-filter="東京建物">東建</button>
          <button class="filter-btn" data-filter="野村不動産HD">野村</button>
          <button class="filter-btn" data-filter="東急不動産HD">東急</button>
        </div>
      </div>
    </div>
    <div class="container">
      <div class="news-scroll-wrapper">
        <div class="news-ticker-track" id="news-ticker-track">
          <!-- renderNews() populates this via JS -->
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Financial Summary -->
  <section class="section" id="summary">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">📋 最新決算サマリー</h2>
          <span class="section-count">単位: 億円</span>
        </div>
      </div>
      <hr class="section-divider" />

      <div class="table-wrap" style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>企業名</th>
              <th>決算期</th>
              <th>営業収益</th>
              <th>前期比</th>
              <th>営業利益</th>
              <th>利益率</th>
              <th>経常利益</th>
              <th>純利益</th>
              <th>ROE</th>
              <th>株価</th>
            </tr>
          </thead>
          <tbody>
            {companies.map((c) => {
              const col = COMPANY_COLORS[c.name] ?? { bg: "#555", accent: "#555", text: "#eee" };
              const mClass = c.profitMargin >= 20 ? "margin-high" : c.profitMargin >= 15 ? "margin-mid" : "margin-low";
              const yoyClass = c.yoyGrowth >= 0 ? "yoy-positive" : "yoy-negative";
              return (
                <tr>
                  <td>
                    <div class="company-label">
                      <div class="company-dot" style={`background:${col.accent}`} />
                      {c.name}
                    </div>
                  </td>
                  <td>{c.period}</td>
                  <td>{c.revenue.toLocaleString()}</td>
                  <td><span class={`yoy-growth ${yoyClass}`}>{c.yoyGrowth > 0 ? '+' : ''}{c.yoyGrowth.toFixed(1)}%</span></td>
                  <td>{c.operatingProfit.toLocaleString()}</td>
                  <td><span class={`margin-pill ${mClass}`}>{c.profitMargin.toFixed(1)}%</span></td>
                  <td>{c.ordinaryProfit.toLocaleString()}</td>
                  <td>{c.netProfit.toLocaleString()}</td>
                  <td>{c.roe.toFixed(1)}%</td>
                  <td>¥{c.stockPrice.toLocaleString()}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Projects -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">🏗️ 再開発プロジェクト</h2>
          <span class="section-count">{projects.length} 件</span>
        </div>
      </div>
      <hr class="section-divider" />

      <div class="table-wrap" style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>企業名</th>
              <th style="text-align:left;">プロジェクト名</th>
              <th>エリア</th>
              <th>規模</th>
              <th>完成予定</th>
              <th>状況</th>
            </tr>
          </thead>
          <tbody>
            {projects.map((p) => {
              const col = COMPANY_COLORS[p.company] ?? { bg: "#555", accent: "#555", text: "#eee" };
              const statusClass = projectStatusMap[p.status] ?? "status-plan";
              return (
                <tr>
                  <td>
                    <div class="company-label">
                      <div class="company-dot" style={`background:${col.accent}`} />
                      {p.company}
                    </div>
                  </td>
                  <td style="text-align:left;">{p.name}</td>
                  <td>{p.location}</td>
                  <td>{p.scale}</td>
                  <td>{p.year}年</td>
                  <td>
                    <span class={`project-status ${statusClass}`}>
                      {p.status}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FOOTER AD BANNER -->
  <div class="ad-banner ad-banner-footer" id="ad-footer">
    <div class="ad-placeholder">
      <span class="ad-placeholder-icon">📢</span>
      AD SPACE — FOOTER（728×90）
    </div>
    <!-- To use: replace .ad-placeholder with:
    <a href="https://example.com" target="_blank" rel="noopener sponsored">
      <img src="https://example.com/banner-728x90.png" alt="Ad" width="728" height="90" loading="lazy" />
    </a>
    -->
  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-inner">
        <p class="footer-text">&copy; 2026 deveryman-ir. データはモック値を含みます。投資判断は自己責任でお願いします。</p>
        <div class="footer-links">
          <a href="https://twitter.com/deveryman_inv" target="_blank">X (Twitter)</a>
          <a href="https://disclosure.edinet-fsa.go.jp/" target="_blank">EDINET</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- SCRIPTS -->
  <script is:inline define:vars={{ newsItems }}>
    function renderNews(filterValue) {
      var track = document.getElementById('news-ticker-track');
      if (!track) return;

      var filtered = filterValue === 'all'
        ? newsItems
        : newsItems.filter(function(n) { return n.company === filterValue; });

      if (filtered.length === 0) {
        track.innerHTML = '<div class="news-empty">現在表示できるニュースはありません</div>';
        track.style.animation = 'none';
        return;
      }

      var displayNews = filterValue === 'all'
        ? filtered.concat(filtered)
        : filtered;

      var colorMap = {
        '三井不動産':   '#4a90d9',
        '三菱地所':     '#e85555',
        '住友不動産':   '#3aaa5c',
        '東京建物':     '#d4813a',
        '野村不動産HD': '#6a6adc',
        '東急不動産HD': '#28b0b0'
      };

      var html = displayNews.map(function(n) {
        var accent = colorMap[n.company] || '#60a5fa';
        return '<a class="news-card" href="' + n.url + '" target="_blank" rel="noopener"'
          + ' style="--accent-color:' + accent + ';">'
          + '<span class="news-card-date">' + n.date + '</span>'
          + '<span class="news-category ' + n.category + '">' + n.category + '</span>'
          + '<span class="news-card-company">' + n.company + '</span>'
          + '<span class="news-card-sep">\u2014</span>'
          + '<span class="news-card-title">' + n.title + '</span>'
          + '<span class="news-card-sep">\uff5c</span>'
          + '<span class="news-card-desc">' + n.desc + '</span>'
        + '</a>';
      }).join('');

      track.innerHTML = html;

      track.style.animation = 'none';
      if (filterValue === 'all') {
        void track.offsetHeight;
        track.style.animation = 'ticker-scroll-vertical 50s linear infinite';
      }
    }

    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        document.querySelectorAll('.filter-btn').forEach(function(b) {
          b.classList.remove('active');
        });
        e.currentTarget.classList.add('active');
        renderNews(e.currentTarget.getAttribute('data-filter'));
      });
    });

    renderNews('all');

    var wrapper = document.getElementById('cards-scroll');
    var btnLeft = document.getElementById('btn-left');
    var btnRight = document.getElementById('btn-right');
    if (wrapper && btnLeft && btnRight) {
      btnLeft.onclick = function() {
        wrapper.scrollBy({ left: -230, behavior: 'smooth' });
      };
      btnRight.onclick = function() {
        wrapper.scrollBy({ left: 230, behavior: 'smooth' });
      };
    }
  </script>

</body>
</html>
