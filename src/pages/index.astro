    /* === MAP === */
    .map-section { position: relative; height: 420px; background: #0f111a; border-radius: 16px; overflow: hidden; margin-top: 24px; border: 1px solid rgba(255,255,255,0.05); }
    .map-title-overlay { position: absolute; top: 16px; left: 16px; z-index: 20; background: rgba(28, 30, 43, 0.85); padding: 8px 14px; border-radius: 10px; font-size: 0.9rem; font-weight: 700; color: #fff; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);}
    
    /* Google Maps Pins (PinElement) */
    .map-pin { transition: all 0.3s ease; cursor: pointer; z-index: 10; opacity: 1; position: relative; }
    .map-pin.is-dimmed { opacity: 0.3; transform: scale(0.85); }
    .map-pin.is-active { z-index: 30; transform: scale(1.3); }
    .map-pin-tooltip { display: none; position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%); background: rgba(28, 30, 43, 0.95); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 10px; padding: 10px 14px; white-space: nowrap; pointer-events: none; z-index: 30; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5); }
    .map-pin.is-active .map-pin-tooltip { display: block; }
    .map-pin-tooltip-company { font-size: 0.72rem; font-weight: 700; margin-bottom: 2px; }
    .map-pin-tooltip-name { font-size: 0.7rem; font-weight: 500; color: rgba(255, 255, 255, 0.7); }

    /* === COMING SOON BADGE === */
    .badge-coming-soon { font-size: 0.6rem; font-weight: 700; background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); padding: 2px 8px; border-radius: 20px; white-space: nowrap; margin-left: 8px; vertical-align: middle; }

    /* === COMING SOON BADGE === */
    .badge-coming-soon { font-size: 0.6rem; font-weight: 700; background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); padding: 2px 8px; border-radius: 20px; white-space: nowrap; margin-left: 8px; vertical-align: middle; }

    /* === FOOTER === */
    .footer { border-top: 1px solid rgba(255, 255, 255, 0.06); padding: 28px 0; margin-top: 40px; }
    .footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .footer-text { font-size: 0.75rem; color: rgba(255, 255, 255, 0.3); }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 0.75rem; color: rgba(255, 255, 255, 0.3); }
    .footer-links a:hover { color: rgba(255, 255, 255, 0.6); }

    /* ==============================
       MOBILE (max-width: 768px)
       ============================== */
    @media (max-width: 768px) {

      /* --- Layout & Spacing --- */
      .container { padding: 0 16px; }
      .section { padding: 24px 0; }
      .hero { padding: 28px 0 16px; }
      .hero-title { font-size: 1.4rem; }
      .hero-sub { font-size: 0.8rem; }
      .hero-eyebrow { font-size: 0.7rem; margin-bottom: 8px; }
      .section-header { flex-direction: column; align-items: flex-start; gap: 10px; }
      .section-title { font-size: 1.05rem; }
      .filter-group { align-self: stretch; }

      /* --- Header --- */
      .nav { display: none; }
      .header-inner { gap: 8px; }
      .logo { font-size: 1.05rem; }
      .badge-updated { font-size: 0.65rem; padding: 3px 8px; }

      /* --- Ad Banner --- */
      .ad-placeholder { max-width: 320px; height: 50px; }
      .ad-banner-header, .ad-banner-footer { min-height: 50px; }
      .ad-banner img { max-height: 50px; }

      /* --- Company Cards --- */
      .scroll-arrow { display: none; }
      .cards-scroll-wrapper { padding: 8px 0 20px; gap: 12px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
      .company-card { min-width: 260px; width: 260px; max-width: 260px; scroll-snap-align: start; }
      .card-top-identity { min-height: 100px; padding: 10px 14px; }
      .company-name { font-size: 1rem; }
      .stat-value-large { font-size: 1.1rem; }
      .card-body { padding: 10px 14px; }
      .metrics-grid-container { gap: 10px 4px; }
      .metric-data { font-size: 0.85rem; }

      /* --- News (横溢れ修正) --- */
      .news-ticker-section { padding: 16px 0; }
      .news-scroll-wrapper { height: 220px; border-radius: 12px; }
      .news-card { padding: 10px 12px; gap: 6px; white-space: normal; flex-wrap: wrap; }
      .news-card-date { font-size: 0.68rem; width: 62px; min-width: 62px; }
      .news-category { font-size: 0.65rem; width: 44px; min-width: 44px; padding: 1px 4px; }
      .news-card-company { font-size: 0.72rem; width: auto; min-width: auto; }
      .news-card-title { font-size: 0.68rem; white-space: normal; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; flex-basis: 100%; margin-top: 4px; order: 10; color: rgba(232,234,240,0.85); }

      /* --- Summary Tables --- */
      .summary-tables-grid { gap: 16px; overflow-x: visible; }
      .table-container { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .table-container .table-wrap { min-width: 560px; }
      .data-table { font-size: 0.72rem; }
      .data-table th { padding: 8px 10px; font-size: 0.65rem; }
      .data-table td { padding: 10px 10px; }
      .data-table td:first-child { min-width: 90px; }
      .company-label { font-size: 0.72rem; gap: 6px; }
      .company-dot { width: 6px; height: 6px; }
      .yoy-growth { font-size: 0.65rem; }
      .margin-pill { font-size: 0.65rem; padding: 1px 6px; }
      .table-meta { font-size: 0.78rem; }
      /* モバイルで公表日列を非表示 */
      #table-highlights thead th:nth-child(3),
      #table-highlights tbody td:nth-child(3) { display: none; }

      /* --- Projects Table --- */
      .map-section { height: 300px; }
      .map-title-overlay { font-size: 0.78rem; padding: 6px 10px; top: 10px; left: 10px; }
      .map-pin-tooltip { display: none !important; }
      #table-projects { font-size: 0.7rem; }
      /* モバイルで規模・用途列を非表示 */
      #table-projects thead th:nth-child(6),
      #table-projects tbody td:nth-child(6),
      #table-projects thead th:nth-child(7),
      #table-projects tbody td:nth-child(7) { display: none; }

      /* --- Filter overflow fix --- */
      .filter-group { flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: 4px; }
      .filter-btn { padding: 5px 10px; font-size: 0.68rem; flex-shrink: 0; }

      /* --- Projects Table horizontal scroll --- */
      #projects .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      #projects .table-wrap > table { min-width: 640px; }

      /* --- Footer --- */
      .footer { padding: 20px 0; margin-top: 24px; }
      .footer-inner { flex-direction: column; align-items: center; text-align: center; gap: 8px; }
      .footer-text { font-size: 0.68rem; }
      .footer-links { gap: 14px; }
      .footer-links a { font-size: 0.68rem; }
    }

    /* ==============================
       SMALL MOBILE (max-width: 420px)
       ============================== */
    @media (max-width: 420px) {
      .container { padding: 0 12px; }
      .company-card { min-width: 240px; width: 240px; max-width: 240px; }
      .hero-title { font-size: 1.2rem; }
      .news-card-date { display: none; }
      .news-card-company { font-size: 0.68rem; }
      .news-card-title { font-size: 0.65rem; }
      .table-container .table-wrap { min-width: 480px; }
      /* 420px以下で経常利益列も非表示 */
      #table-highlights thead th:nth-child(6),
      #table-highlights tbody td:nth-child(6) { display: none; }
    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <div class="header-inner">
        <a href="https://twitter.com/deveryman_inv" target="_blank" rel="noopener" class="twitter-link" aria-label="X (Twitter) - @deveryman_inv"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
        <a href="https://querie.me/user/deveryman_inv" target="_blank" rel="noopener" class="querie-link" aria-label="質問箱 - Querie.me" style="margin-left: 8px; color: rgba(255,255,255,0.5); transition: color 0.2s;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></a>
        <div class="logo">deveryman<span>-ir</span></div>
        <nav class="nav">
          <a href="#companies">株式・市場データ</a>
          <a href="#news">ニュース</a>
          <a href="#summary">業績ハイライト</a>
          <a href="#projects">再開発PJ</a>
          <a style="color: rgba(255, 255, 255, 0.3); pointer-events: none; cursor: default;" aria-disabled="true">住宅マーケット<span class="badge-coming-soon">公開予定</span></a>
          <a style="color: rgba(255, 255, 255, 0.3); pointer-events: none; cursor: default;" aria-disabled="true">販売中・予定住宅MAP<span class="badge-coming-soon">公開予定</span></a>
        </nav>
        <div class="header-actions">
          <div class="badge-updated" id="header-updated-at">更新: {updatedAt}</div>
        </div>
      </div>
    </div>
  </header>

  <BannerArea position="top" />

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">Real Estate Developer IR Dashboard</p>
      <h1 class="hero-title">大手不動産デベロッパー<br /><em>最新IR情報</em></h1>
      <p class="hero-sub">三井・三菱・住友・東建・野村・東急<br />決算データ・再開発プロジェクトを一覧</p>
    </div>
  </section>

  <!-- SECTION 1: 企業カード -->
  <section class="section" id="companies">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">📊 株式・市場データ</h2>
        </div>
      </div>
      <div class="cards-row">
        <button class="scroll-arrow scroll-arrow-left" style="margin-right:12px;" id="btn-left" aria-label="左へスクロール">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="cards-scroll-wrapper" id="cards-scroll">
          {companies.map(c => {
            const col = COMPANY_COLORS[c.name] || { bg: "#222", accent: "#888", text: "#eee" };
            const live = liveMap[c.code];
            const stockPrice = live?.stock ?? c.stock;
            const mCapVal = live?.mCap;
            const unit = (c.name.includes("不動産") && !c.name.includes("野村") && !c.name.includes("東急")) || c.name === "三菱地所" ? "兆円" : "億円";
            const mCapStr = mCapVal ? (mCapVal >= 10000 ? `${(mCapVal/10000).toFixed(2)}` : `${Math.round(mCapVal).toLocaleString()}`) : c.mCap;
            const mCapUnit = mCapVal ? (mCapVal >= 10000 ? "兆円" : "億円") : unit;
            const roe = live?.roe ?? c.roe;
            const pbr = live?.pbr ?? c.pbr;
            const divYield = live?.divYield ?? c.yield;
            const change = live?.change;
            const changeStr = change !== null && change !== undefined ? `${change >= 0 ? "+" : ""}${change.toFixed(2)}%` : null;
            return (
              <article class="company-card">
                <div class="card-top-identity" style={`background: linear-gradient(135deg, ${col.bg} 0%, ${col.accent} 100%);`}>
                  <div class="company-header-row">
                    <div class="logo-box"><span class="logo-fallback" style={`color:${col.bg}`}>{c.initial}</span></div>
                    <div class="company-name">{c.name}</div>
                    <div class="sec-code">TSE {c.code}</div>
                  </div>
                  <div class="hero-stats-grid">
                    <div class="stat-item">
                      <div style="display:flex; align-items:flex-end; gap:10px;">
                        <div>
                          <span class="stat-label-colored">株価</span>
                          <div class="stat-value-large">{stockPrice ? stockPrice.toLocaleString() : "---"}<span class="unit-hero">円</span></div>
                        </div>
                        <div style="padding-bottom:2px;">
                          <span class="stat-label-colored" style="font-size:.5rem;">前日比</span>
                          {changeStr ? <div style={`font-size:.7rem; font-weight:800; font-family:'Inter',sans-serif; color:${change >= 0 ? "#2ecc8a" : "#e8504a"}; white-space:nowrap; line-height:1.3;`}>{changeStr}</div> : <div style="font-size:.7rem; color:rgba(255,255,255,0.3);">---</div>}
                        </div>
                      </div>
                    </div>
                    <div class="stat-item">
                      <span class="stat-label-colored">時価総額</span>
                      <div class="stat-value-large" style="display:flex; align-items:baseline;">{mCapStr}<span class="unit-hero">{mCapUnit}</span></div>
                    </div>
                  </div>
                </div>
                <div class="card-body">
                  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; min-height:24px;"><div class="fiscal-badge" style="margin:0; line-height:1.4;">{live?.period ? `${live.period} ${live.badge ?? ""}` : c.badge}</div><a href={c.irLink} target="_blank" rel="noopener" class="ir-link-btn" style="margin:0; line-height:1.4;">IRサイト ↗</a></div>
                  <div class="metrics-grid-container">
                    <div class="metric-group">
                      <span class="metric-title">売上高</span>
                      <div class="metric-data">{live?.revenue ? (live.revenue >= 10000 ? `${(live.revenue/10000).toFixed(2)}` : live.revenue.toLocaleString()) : c.revenueStr}<span class="unit-small">{(live?.revenue ?? c.revenue) >= 10000 ? "兆" : "億"}</span></div>
                    </div>
                    <div class="metric-group">
                      <span class="metric-title">営業利益</span>
                      <div class="metric-data">{(live?.op ?? c.op).toLocaleString()}<span class="unit-small">億</span></div>
                    </div>
                    <div class="metric-group">
                      <span class="metric-title">純利益</span>
                      <div class="metric-data">{(live?.net ?? c.net).toLocaleString()}<span class="unit-small">億</span></div>
                    </div>
                    <div class="metric-group">
                      <span class="metric-title valuation">ROE</span>
                      <div class="metric-data">{roe ? roe.toFixed(1) : "---"}<span class="unit-small">%</span></div>
                    </div>
                    <div class="metric-group">
                      <span class="metric-title valuation">PBR</span>
                      <div class="metric-data">{pbr ? pbr.toFixed(2) : "---"}<span class="unit-small">x</span></div>
                    </div>
                    <div class="metric-group">
                      <span class="metric-title valuation">利回り</span>
                      <div class="metric-data">{divYield ? divYield.toFixed(1) : "---"}<span class="unit-small">%</span></div>
                    </div>
                  </div>
                </div>
              </article>
            )
          })}
        </div>
        <button class="scroll-arrow scroll-arrow-right" style="margin-left:12px;" id="btn-right" aria-label="右へスクロール">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- SECTION 2: ニュース (JSで動的描画) -->
  <section class="news-ticker-section" id="news">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">📰 最新ニュース & IRリリース</h2><span style="font-size:0.65rem; font-weight:400; color:rgba(255,255,255,0.4); display:block; margin-top:2px;">直近3ヶ月 · 主要ニュースのみ</span>
        </div>
        <div class="filter-group" id="news-filter">
          <button class="filter-btn active" data-filter="all">すべて</button>
          <button class="filter-btn" data-filter="三井不動産">三井</button>
          <button class="filter-btn" data-filter="三菱地所">三菱</button>
          <button class="filter-btn" data-filter="住友不動産">住友</button>
          <button class="filter-btn" data-filter="東京建物">東建</button>
          <button class="filter-btn" data-filter="野村不動産HD">野村</button>
          <button class="filter-btn" data-filter="東急不動産HD">東急</button>
        </div>
      </div>
    </div>
    <div class="container">
      <div class="news-scroll-wrapper">
        <div class="news-ticker-track" id="news-ticker-track">
          <!-- JS Rendered -->
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: 決算サマリー -->
  <section class="section" id="summary">
    <div class="container">
      <h2 class="section-title">📋 業績ハイライト & 分譲戸数(予想)</h2>
      <div class="summary-tables-grid">
        <!-- 業績ハイライト -->
        <div class="table-container">
          <div class="table-meta">業績ハイライト<span>単位: 億円</span></div>
          <div class="table-wrap">
            <table class="data-table" id="table-highlights">
              <thead>
                <tr>
                  <th>企業名</th>
                  <th style="text-align:center;">期</th><th style="text-align:center;">公表日</th>
                  <th>売上高 <span>(前期比)</span></th>
                  <th>営業利益 <span>(率)</span></th>
                  <th>経常利益 <span>(前期比)</span></th>
                  <th>純利益 <span>(前期比)</span></th>
                </tr>
              </thead>
              <tbody>
                {mergedCompanies.map(c => {
                  const col = COMPANY_COLORS[c.name] || { bg: "#555", accent: "#555" };
                  const yoyClass = c.revYoy >= 0 ? 'yoy-positive' : 'yoy-negative';
                  const ordYoyClass = c.ordYoy >= 0 ? 'yoy-positive' : 'yoy-negative';
                  const netYoyClass = c.netYoy >= 0 ? 'yoy-positive' : 'yoy-negative';
                  return (
                    <tr>
                      <td>
                        <div class="company-label">
                          <div class="company-dot" style={`background:${col.accent}`}></div>
                          {c.name}
                        </div>
                      </td>
                      <td style="text-align:center">{c.period}</td><td style="text-align:center; color:rgba(255,255,255,0.5); font-size:0.78rem;">{c.announcedAt}</td>
                      <td>
                        {c.revenue.toLocaleString()}
                        <span class={`yoy-growth ${yoyClass}`}>({c.revYoy > 0 ? '+' : ''}{c.revYoy.toFixed(1)}%)</span>
                      </td>
                      <td>
                        {c.op.toLocaleString()}
                        <span class={`margin-pill ${getMarginClass(c.margin)}`}>{c.margin.toFixed(1)}%</span>
                      </td>
                      <td>
                        {c.ord.toLocaleString()}
                        <span class={`yoy-growth ${ordYoyClass}`}>({c.ordYoy > 0 ? '+' : ''}{c.ordYoy.toFixed(1)}%)</span>
                      </td>
                      <td>
                        {c.net.toLocaleString()}
                        <span class={`yoy-growth ${netYoyClass}`}>({c.netYoy > 0 ? '+' : ''}{c.netYoy.toFixed(1)}%)</span>
                      </td>
                    </tr>
                  )
                })}
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- 分譲戸数 -->
        <div class="table-container">
          <div class="table-meta">分譲戸数 (予想)<span>単位: 戸</span></div>
          <div class="table-wrap">
            <table class="data-table" id="table-condo">
              <thead>
                <tr>
                  <th>企業名</th>
                  <th>計上戸数 <span>(前期比)</span></th>
                  <th>営業利益率</th>
                  <th style="text-align:left;">主な分譲実績</th>
                </tr>
              </thead>
              <tbody>
                {mergedCompanies.map(c => {
                  const col = COMPANY_COLORS[c.name] || { bg: "#555", accent: "#555" };
                  const unitYoyClass = c.unitYoy >= 0 ? 'yoy-positive' : 'yoy-negative';
                  return (
                    <tr>
                      <td>
                        <div class="company-label">
                          <div class="company-dot" style={`background:${col.accent}`}></div>
                          {c.name}
                        </div>
                      </td>
                      <td>
                        {c.units.toLocaleString()}
                        <span class={`yoy-growth ${unitYoyClass}`}>({c.unitYoy > 0 ? '+' : ''}{c.unitYoy.toFixed(1)}%)</span>
                      </td>
                      <td>
                        <span class={`margin-pill ${getMarginClass(c.unitMargin)}`}>{c.unitMargin.toFixed(1)}%</span>
                      </td>
                      <td style="text-align:left;">
                        <div style="font-size:0.65rem; color:rgba(255,255,255,0.35); font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:3px;">{c.brandName}</div>
                        <div style="font-size:0.78rem; color:#e8eaf0; white-space:nowrap;">
                          <span style="color:rgba(255,255,255,0.3); margin-right:4px;">›</span>{c.deliveries[0]}
                        </div>
                      </td>
                    </tr>
                  )
                })}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: プロジェクト -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">🏗️ 再開発プロジェクト（都内主要）</h2>
          <span class="section-count" id="projects-count-display">{projects.length} 件</span>
        </div>
        <div class="filter-group" id="projects-filter">
          <button class="filter-btn active" data-filter="all">すべて</button>
          <button class="filter-btn" data-filter="三井不動産">三井</button>
          <button class="filter-btn" data-filter="三菱地所">三菱</button>
          <button class="filter-btn" data-filter="住友不動産">住友</button>
          <button class="filter-btn" data-filter="東京建物">東建</button>
          <button class="filter-btn" data-filter="野村不動産HD">野村</button>
          <button class="filter-btn" data-filter="東急不動産HD">東急</button>
　　　　　　<button class="filter-btn" data-filter="その他">その他</button>
        </div>
      </div>
      
      <!-- MAP -->
      <div class="map-section" style="height: 520px;">
        <div class="map-title-overlay">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>
          開発エリア マップ
        </div>
        <!-- Google Maps コンテナ -->
        <div id="google-map" style="position: absolute; inset: 0; width: 100%; height: 100%;"></div>
      </div>
      <div class="table-wrap" style="width: 100%; max-height: 440px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.08) transparent;">
        <table class="data-table" id="table-projects" style="width: 100%;">
          <thead>
            <tr>
              <th>企業名</th>
              <th style="text-align:center; padding-right:4px;">状況</th>
              <th style="padding-left:4px;">完成予定</th>
              <th style="text-align:left;">プロジェクト名</th>
              <th style="text-align:left;">エリア</th>
              <th style="text-align:left;">規模</th>
              <th style="text-align:left;">用途</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="projects-tbody">
            {sortedProjects.map(p => {
              const statusClass = projectStatusMap[p.status] || "status-plan";
              return (
                <tr class="project-row" data-project-id={p.id} data-company={p.company}>
                  <td>
                    <div class="company-label">
                      <div class="company-dot" style={`background:${p.color}; box-shadow: 0 0 8px ${p.color};`}></div>
                      {p.company}
                    </div>
                  </td>
                  <td style="text-align:center; padding-right:4px;">
                    <span class={`project-status ${statusClass}`}>{p.status}</span>
                  </td>
                  <td style="text-align:right; padding-left:4px;">{p.completion}</td>
                  <td style="text-align:left; font-weight:700; color:#e8eaf0;">{p.name}</td>
                  <td style="text-align:left;">{p.area}</td>
                  <td style="text-align:left;">{p.scale}</td>
                  <td style="text-align:left; color:rgba(255,255,255,0.6);">{p.usage}</td>
                  <td style="text-align:center;">
                    <a href={p.irLink} target="_blank" rel="noopener" class="ir-link-btn">↗</a>
                  </td>
                </tr>
              )
            })}
          </tbody>
        </table>
      </div>

    </div>
  </section>

  <BannerArea position="bottom" />

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-inner">
        <p class="footer-text">&copy; 2026 deveryman-ir. 当サイトは投資助言を目的としたものではありません。</p>
        <div class="footer-links">
          <a href="https://twitter.com/deveryman_inv" target="_blank">X (Twitter)</a>
          <a href="https://disclosure.edinet-fsa.go.jp/" target="_blank">EDINET</a>
          <a href="/policy">免責事項・ポリシー</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- SCRIPTS -->
  <script is:inline define:vars={{ newsItems, projects, COMPANY_COLORS }}>
    // --- ニュースセクションの描画 ---
    function renderNews(filterValue) {
      var track = document.getElementById('news-ticker-track');
      var wrapper = document.querySelector('.news-scroll-wrapper');
      if (!track) return;

      var filtered = filterValue === 'all'
        ? newsItems
        : newsItems.filter(function(n) { return n.company === filterValue; });

      if (filtered.length === 0) {
        track.innerHTML = '<div class="news-empty">現在表示できるニュースはありません</div>';
        track.style.animation = 'none';
        return;
      }

      var displayNews = filterValue === 'all'
        ? filtered.concat(filtered)
        : filtered;

      var html = displayNews.map(function(n) {
        var accent = COMPANY_COLORS[n.company] ? COMPANY_COLORS[n.company].accent : '#60a5fa';
        return '<a class="news-card" href="' + n.url + '" target="_blank" rel="noopener"'
          + ' style="--accent-color:' + accent + ';">'
          + '<span class="news-card-date">' + n.date + '</span>'
          + '<span class="news-category ' + n.category + '">' + n.category + '</span>'
          + '<span class="news-card-company">' + n.company + '</span>'
          + '<span class="news-card-sep">\u2014</span>'
          + '<span class="news-card-title">' + n.title + '</span>'
          
        + '</a>';
      }).join('');

      track.innerHTML = html;

      var wrapper = document.querySelector('.news-scroll-wrapper');
      track.style.animation = 'none';
      if (filterValue === 'all') {
        wrapper.style.overflowY = 'hidden';
        void track.offsetHeight;
        track.style.animation = 'ticker-scroll-vertical 180s linear infinite';
      } else {
        wrapper.style.overflowY = 'auto';
      }
    }

    // ニュース用フィルターボタンのイベント
    document.querySelectorAll('#news-filter .filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        document.querySelectorAll('#news-filter .filter-btn').forEach(function(b) {
          b.classList.remove('active');
        });
        e.currentTarget.classList.add('active');
        renderNews(e.currentTarget.getAttribute('data-filter'));
      });
    });

    renderNews('all');

    // 企業カードの横スクロール
    var wrapper = document.getElementById('cards-scroll');
    var btnLeft = document.getElementById('btn-left');
    var btnRight = document.getElementById('btn-right');
    if (wrapper && btnLeft && btnRight) {
      btnLeft.onclick = function() {
        wrapper.scrollBy({ left: -256, behavior: 'smooth' });
      };
      btnRight.onclick = function() {
        wrapper.scrollBy({ left: 256, behavior: 'smooth' });
      };
    }

    // --- Google Maps と プロジェクトフィルタリングの実装 ---
    let map;
    const mapMarkers = {};
    const googleMarkers = {};

    async function initGoogleMap() {
      const API_KEY = "AIzaSyAGRPnbJ8ePZnUcf8VVuBU1KDfkz5Z7W4k"; 
      const MAP_ID = "cf42d31342c76186d63584b1";

      await new Promise((resolve) => {
        if(window.google && window.google.maps) { resolve(); return; }
        const script = document.createElement("script");
        script.src = `https://maps.googleapis.com/maps/api/js?key=${API_KEY}&libraries=marker&v=beta`;
        script.async = true;
        script.onload = resolve;
        document.head.appendChild(script);
      });

      const darkMapStyle = [
        { elementType: "geometry", stylers: [{ color: "#1a1f3a" }] },
        { elementType: "labels.text.stroke", stylers: [{ color: "#1a1f3a" }] },
        { elementType: "labels.text.fill", stylers: [{ color: "#818cf8" }] },
        { featureType: "water", elementType: "geometry", stylers: [{ color: "#0a0f1e" }] },
        { featureType: "road", elementType: "geometry", stylers: [{ color: "#2a3041" }] },
        { featureType: "road", elementType: "geometry.stroke", stylers: [{ color: "#1a1f3a" }] },
        { featureType: "poi", stylers: [{ visibility: "off" }] },
        { featureType: "transit", stylers: [{ visibility: "simplified" }] },
      ];

      map = new google.maps.Map(document.getElementById("google-map"), {
        center: { lat: 35.676, lng: 139.755 },
        zoom: 12.5,
        mapId: MAP_ID,
        styles: darkMapStyle,
        disableDefaultUI: true,
        zoomControl: true,
      });

      const { AdvancedMarkerElement, PinElement } = await google.maps.importLibrary("marker");

      projects.forEach(p => {
        if (!p.location) return;

        // Google Maps標準ピン（各社カラー）
        const pin = new PinElement({
          background: p.color,
          borderColor: '#ffffff',
          glyphColor: '#ffffff',
          scale: 0.7,
        });

        // ホバー連動用のラッパー
        const pinContainer = document.createElement("div");
        pinContainer.className = "map-pin";
        pinContainer.dataset.projectId = p.id;
        pinContainer.style.position = "relative";
        pinContainer.appendChild(pin.element);

        // ツールチップ
        const tooltip = document.createElement("div");
        tooltip.className = "map-pin-tooltip";
        tooltip.innerHTML = `
          <div class="map-pin-tooltip-company" style="color:${p.color};">${p.company}</div>
          <div class="map-pin-tooltip-name">${p.name}</div>
        `;
        pinContainer.appendChild(tooltip);

        const marker = new AdvancedMarkerElement({
          map,
          position: p.location,
          content: pinContainer,
          title: p.name,
        });

        mapMarkers[p.id] = pinContainer;
        googleMarkers[p.id] = marker;

        pinContainer.addEventListener('mouseenter', () => window.updateHoverState(p.id));
        pinContainer.addEventListener('mouseleave', () => window.updateHoverState(null));
      });
    }

    // --- プロジェクトセクションのフィルタリング機能 ---
    function filterProjects(company) {
      var rows = document.querySelectorAll('.project-row');
      var visibleCount = 0;

      rows.forEach(function(row) {
        if (company === 'all' || row.getAttribute('data-company') === company) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });

      var countEl = document.getElementById('projects-count-display');
      if (countEl) countEl.innerText = visibleCount + ' 件';

      projects.forEach(function(p) {
        var marker = googleMarkers[p.id];
        if (marker) {
          if (company === 'all' || p.company === company) {
            marker.map = map;
          } else {
            marker.map = null;
          }
        }
      });
    }

    document.querySelectorAll('#projects-filter .filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        document.querySelectorAll('#projects-filter .filter-btn').forEach(function(b) {
          b.classList.remove('active');
        });
        e.currentTarget.classList.add('active');
        filterProjects(e.currentTarget.getAttribute('data-filter'));
      });
    });

    // ---- Project table <-> Map pin hover linkage ----
    function setupProjectHover() {
      var rows = document.querySelectorAll('.project-row');

      window.updateHoverState = function(hoveredId) {
        rows.forEach(function(row) {
          if (hoveredId && row.dataset.projectId === hoveredId) {
            row.classList.add('is-hovered');
          } else {
            row.classList.remove('is-hovered');
          }
        });
        
        Object.values(mapMarkers).forEach(function(pin) {
          if (hoveredId === null) {
            pin.classList.remove('is-dimmed', 'is-active');
          } else if (pin.dataset.projectId === hoveredId) {
            pin.classList.remove('is-dimmed');
            pin.classList.add('is-active');
          } else {
            pin.classList.remove('is-active');
            pin.classList.add('is-dimmed');
          }
        });
      };

      rows.forEach(function(row) {
        row.addEventListener('mouseenter', function() { window.updateHoverState(row.dataset.projectId); });
        row.addEventListener('mouseleave', function() { window.updateHoverState(null); });
      });
    }

    initGoogleMap().catch(e => console.error("Google Maps failed to load", e));
    setupProjectHover();

  </script>
</body>
</html>
