   902	  <!-- ═══════════════════════════════════════
   903	       SCRIPTS
   904	       ═══════════════════════════════════════ -->
   905	  <script is:inline define:vars={{ newsItems }}>
   906	    // ────────────────────────────────────
   907	    //  renderNews: ニュースをJSのみで描画
   908	    // ────────────────────────────────────
   909	    function renderNews(filterValue) {
   910	      var track = document.getElementById('news-ticker-track');
   911	      if (!track) return;
   912	
   913	      var filtered = filterValue === 'all'
   914	        ? newsItems
   915	        : newsItems.filter(function(n) { return n.company === filterValue; });
   916	
   917	      if (filtered.length === 0) {
   918	        track.innerHTML = '<div class="news-empty">現在表示できるニュースはありません</div>';
   919	        track.style.animation = 'none';
   920	        return;
   921	      }
   922	
   923	      var displayNews = filterValue === 'all'
   924	        ? filtered.concat(filtered)
   925	        : filtered;
   926	
   927	      var colorMap = {
   928	        '三井不動産':   '#4a90d9',
   929	        '三菱地所':     '#e85555',
   930	        '住友不動産':   '#3aaa5c',
   931	        '東京建物':     '#d4813a',
   932	        '野村不動産HD': '#6a6adc',
   933	        '東急不動産HD': '#28b0b0'
   934	      };
   935	
   936	      var html = displayNews.map(function(n) {
   937	        var accent = colorMap[n.company] || '#60a5fa';
   938	        return '<a class="news-card" href="' + n.url + '" target="_blank" rel="noopener"'
   939	          + ' style="--accent-color:' + accent + '; --accent-glow:' + accent + '33;">'
   940	          + '<span class="news-card-meta">'
   941	            + '<span class="news-card-date">' + n.date + '</span>'
   942	            + '<span class="news-category ' + n.category + '">' + n.category + '</span>'
   943	            + '<span class="news-card-company">' + n.company + '</span>'
   944	          + '</span>'
   945	          + '<span class="news-card-body">'
   946	            + '<span class="news-card-title">' + n.title + '</span>'
   947	            + '<span class="news-card-sep">\u2014</span>'
   948	            + '<span class="news-card-desc">' + n.desc + '</span>'
   949	          + '</span>'
   950	        + '</a>';
   951	      }).join('');
   952	
   953	      track.innerHTML = html;
   954	
   955	      track.style.animation = 'none';
   956	      if (filterValue === 'all') {
   957	        void track.offsetHeight;
   958	        track.style.animation = 'ticker-scroll-vertical 50s linear infinite';
   959	      }
   960	    }
   961	
   962	    // ────────────────────────────────────
   963	    //  フィルターボタン
   964	    // ────────────────────────────────────
   965	    document.querySelectorAll('.filter-btn').forEach(function(btn) {
   966	      btn.addEventListener('click', function(e) {
   967	        document.querySelectorAll('.filter-btn').forEach(function(b) {
   968	          b.classList.remove('active');
   969	        });
   970	        e.currentTarget.classList.add('active');
   971	        renderNews(e.currentTarget.getAttribute('data-filter'));
   972	      });
   973	    });
   974	
   975	    // 初期描画
   976	    renderNews('all');
   977	
   978	    // ────────────────────────────────────
   979	    //  企業カード横スクロールボタン
   980	    // ────────────────────────────────────
   981	    var wrapper = document.getElementById('cards-scroll');
   982	    var btnLeft = document.getElementById('btn-left');
   983	    var btnRight = document.getElementById('btn-right');
   984	    if (wrapper && btnLeft && btnRight) {
   985	      btnLeft.onclick = function() {
   986	        wrapper.scrollBy({ left: -230, behavior: 'smooth' });
   987	      };
   988	      btnRight.onclick = function() {
   989	        wrapper.scrollBy({ left: 230, behavior: 'smooth' });
   990	      };
   991	    }
   992	  </script>
