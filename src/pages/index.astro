---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>大手不動産デベロッパー IR ダッシュボード | deveryman-ir</title>
  <meta name="description" content="三井不動産・三菱地所など大手6社の最新決算・再開発情報をまとめて確認" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />

  <style>
    /* ─── RESET & BASE ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: "Noto Sans JP", -apple-system, sans-serif;
      background: #0a0f1e;
      color: #e8eaf0;
      min-height: 100vh;
      line-height: 1.6;
    }
    a { color: inherit; text-decoration: none; }

    /* ─── LAYOUT ─── */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

    /* ─── HEADER ─── */
    .header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,15,30,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding: 16px 0;
    }
    .header-inner {
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      font-size: 1.25rem; font-weight: 900; letter-spacing: -0.02em;
      background: linear-gradient(90deg, #60a5fa, #a78bfa);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .logo span { font-weight: 400; opacity: 0.7; }
    .nav { display: flex; gap: 24px; }
    .nav a {
      font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.6);
      transition: color 0.2s;
    }
    .nav a:hover { color: #fff; }
    .badge-updated {
      font-size: 0.75rem; background: rgba(96,165,250,0.15);
      border: 1px solid rgba(96,165,250,0.3);
      color: #93c5fd; padding: 4px 12px; border-radius: 20px;
    }

    /* ─── HERO ─── */
    .hero {
      padding: 40px 0 24px;
      background: radial-gradient(ellipse at 50% -20%, rgba(96,165,250,0.12) 0%, transparent 70%);
      text-align: center;
    }
    .hero-eyebrow {
      font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: #60a5fa; margin-bottom: 12px;
    }
    .hero-title {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 900;
      line-height: 1.2; margin-bottom: 12px;
    }
    .hero-title em {
      font-style: normal;
      background: linear-gradient(90deg, #60a5fa, #a78bfa, #f472b6);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .hero-sub {
      font-size: 0.88rem; color: rgba(255,255,255,0.5);
      max-width: 480px; margin: 0 auto;
    }

    /* ─── SECTION HEADER ─── */
    .section { padding: 32px 0; }
    .section-header {
      display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px;
    }
    .section-title {
      font-size: 1.1rem; font-weight: 700;
    }
    .section-count {
      font-size: 0.75rem; color: rgba(255,255,255,0.4);
    }
    .section-divider {
      border: none; border-top: 1px solid rgba(255,255,255,0.08); margin-bottom: 20px;
    }

    /* ─── COMPANY CARDS (横1行スクロール) ─── */
    .cards-nav {
      display: flex; justify-content: flex-end; gap: 8px; margin-bottom: 10px;
    }
    .nav-btn {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      color: #fff;
      width: 32px; height: 32px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1rem;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .nav-btn:hover { background: rgba(255,255,255,0.15); }
    .cards-scroll-wrapper {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-behavior: smooth;
      scrollbar-width: none;
      padding-bottom: 8px;
    }
    .cards-scroll-wrapper::-webkit-scrollbar { display: none; }
    .company-card {
      min-width: 200px;
      max-width: 210px;
      flex-shrink: 0;
      border-radius: 12px;
      overflow: hidden;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: pointer;
    }
    .company-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.4);
    }
    .card-header {
      padding: 10px 12px 8px;
      position: relative;
    }
    .card-header-bg {
      position: absolute; inset: 0;
      opacity: 0.9;
    }
    .card-header-content { position: relative; z-index: 1; }
    .card-top-row {
      display: flex; align-items: flex-start; justify-content: space-between;
      margin-bottom: 4px;
    }
    .company-name {
      font-size: 0.88rem; font-weight: 700; color: #fff;
    }
    .sec-code { font-size: 0.7rem; color: rgba(255,255,255,0.6); }

    .card-body { padding: 10px 12px 12px; }
    .fiscal-badge {
      font-size: 0.65rem; font-weight: 600; letter-spacing: 0.05em;
      background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.8);
      padding: 2px 8px; border-radius: 20px; white-space: nowrap; width: fit-content;
      margin-bottom: 8px;
    }

    .metrics-mini {
      display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px;
    }
    .metric-row {
      display: flex; justify-content: space-between; align-items: baseline;
    }
    .metric-label {
      font-size: 0.65rem; color: rgba(255,255,255,0.45);
    }
    .metric-value {
      font-size: 0.8rem; font-weight: 700; color: #e8eaf0;
    }

    .margin-bar-wrap { margin-bottom: 10px; }
    .margin-bar-label {
      display: flex; justify-content: space-between;
      font-size: 0.65rem; color: rgba(255,255,255,0.5); margin-bottom: 4px;
    }
    .margin-bar-track {
      height: 3px; background: rgba(255,255,255,0.1); border-radius: 99px; overflow: hidden;
    }
    .margin-bar-fill {
      height: 100%; border-radius: 99px;
      background: linear-gradient(90deg, #34d399, #10b981);
      transition: width 0.8s ease;
    }

    .card-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.07);
    }
    .stock-info { font-size: 0.7rem; color: rgba(255,255,255,0.5); }
    .stock-info strong { color: #e8eaf0; font-weight: 600; }
    .ir-link {
      font-size: 0.68rem; font-weight: 600; color: #93c5fd;
      display: flex; align-items: center; gap: 3px;
      background: rgba(96,165,250,0.1); padding: 3px 8px; border-radius: 6px;
      transition: background 0.2s;
    }
    .ir-link:hover { background: rgba(96,165,250,0.2); }

/* ─── NEWS TICKER (縦スクロールアニメーション) ─── */
.news-ticker-section {
  background: rgba(255,255,255,0.02);
  border-top: 1px solid rgba(255,255,255,0.08);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  padding: 20px 0;
}
.news-scroll-wrapper {
  height: 400px;
  overflow: hidden;
  position: relative;
}
.news-ticker-track {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.news-ticker-track:hover { animation-play-state: paused; }
@keyframes ticker-scroll-vertical {
  0%   { transform: translateY(0); }
  100% { transform: translateY(-50%); }
}
.news-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 14px 16px;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  flex-shrink: 0;
}
.news-card:hover { 
  border-color: rgba(96,165,250,0.4);
  background: rgba(255,255,255,0.06);
}
.news-card-top { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.news-card-date { font-size: 0.7rem; color: rgba(255,255,255,0.4); }
.news-category {
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.05em;
  padding: 2px 8px; border-radius: 4px; white-space: nowrap;
}
.news-category.IR {
  background: rgba(96,165,250,0.15); color: #93c5fd;
}
.news-category.PR {
  background: rgba(167,139,250,0.15); color: #c4b5fd;
}
.news-card-title { font-size: 0.85rem; font-weight: 700; color: #e8eaf0; margin-bottom: 6px; line-height: 1.4; }
.news-card-desc { font-size: 0.72rem; color: rgba(255,255,255,0.5); line-height: 1.5; }

    /* ─── SUMMARY TABLE ─── */
    .table-wrap {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px; overflow: hidden;
    }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th {
      background: rgba(255,255,255,0.05);
      padding: 10px 14px; text-align: right;
      font-size: 0.7rem; font-weight: 600; color: rgba(255,255,255,0.45);
      letter-spacing: 0.05em; white-space: nowrap;
    }
    .data-table th:first-child { text-align: left; }
    .data-table td {
      padding: 12px 14px; text-align: right;
      font-size: 0.82rem; font-weight: 500; color: #e8eaf0;
      border-top: 1px solid rgba(255,255,255,0.05);
      white-space: nowrap;
    }
    .data-table td:first-child { text-align: left; }
    .data-table tr:hover td { background: rgba(255,255,255,0.03); }
    .company-label {
      display: flex; align-items: center; gap: 8px;
    }
    .company-dot {
      width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    }
    .yoy-growth { font-size: 0.75rem; font-weight: 600; }
    .yoy-positive { color: #34d399; }
    .yoy-negative { color: #f87171; }
    .margin-pill {
      display: inline-block; padding: 2px 8px; border-radius: 20px;
      font-size: 0.72rem; font-weight: 600;
    }
    .margin-high { background: rgba(52,211,153,0.15); color: #34d399; }
    .margin-mid  { background: rgba(251,191,36,0.15);  color: #fbbf24; }
    .margin-low  { background: rgba(239,68,68,0.15);   color: #f87171; }

    /* ─── PROJECTS TABLE ─── */
    .project-status {
      display: inline-block; font-size: 0.7rem; font-weight: 600;
      padding: 3px 10px; border-radius: 20px;
    }
    .status-active   { background: rgba(52,211,153,0.15); color: #34d399; }
    .status-plan     { background: rgba(251,191,36,0.15);  color: #fbbf24; }
    .status-complete { background: rgba(148,163,184,0.15); color: #94a3b8; }
    .status-started  { background: rgba(96,165,250,0.15);  color: #93c5fd; }

    /* ─── FOOTER ─── */
    .footer {
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 28px 0; margin-top: 40px;
    }
    .footer-inner {
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 12px;
    }
    .footer-text { font-size: 0.75rem; color: rgba(255,255,255,0.3); }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 0.75rem; color: rgba(255,255,255,0.3); }
    .footer-links a:hover { color: rgba(255,255,255,0.6); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .nav { display: none; }
      .hero-title { font-size: 1.4rem; }
      .data-table { font-size: 0.72rem; }
      .data-table th, .data-table td { padding: 8px 8px; }
    }
  </style>
</head>

<body>

  <!-- ─── HEADER ─── -->
  <header class="header">
    <div class="container">
      <div class="header-inner">
        <div class="logo">deveryman<span>-ir</span></div>
        <nav class="nav">
          <a href="#companies">企業カード</a>
          <a href="#news">ニュース</a>
          <a href="#summary">決算サマリー</a>
          <a href="#projects">再開発PJ</a>
        </nav>
        <div class="badge-updated">更新: {updatedAt}</div>
      </div>
    </div>
  </header>

  <!-- ─── HERO ─── -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">Real Estate Developer IR Dashboard</p>
      <h1 class="hero-title">大手不動産デベロッパー<br /><em>6社の最新IR情報</em></h1>
      <p class="hero-sub">三井・三菱・住友・東建・野村・東急<br />決算データ・再開発プロジェクトを一覧</p>
    </div>
  </section>

  <!-- ─── SECTION 1: 企業カード (横1行スクロール) ─── -->
  <section class="section" id="companies">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">📊 企業カード</h2>
        <span class="section-count">{companies.length}社</span>
      </div>
      <hr class="section-divider" />

      <div class="cards-nav">
        <button class="nav-btn" id="btn-left">◀</button>
        <button class="nav-btn" id="btn-right">▶</button>
      </div>

      <div class="cards-scroll-wrapper" id="cards-scroll">
        {companies.map((c) => {
          const col = COMPANY_COLORS[c.name] ?? { bg: "#222", accent: "#888", text: "#eee" };
          return (
            <article class="company-card">
              <div class="card-header">
                <div class="card-header-bg" style={`background: linear-gradient(135deg, ${col.bg} 0%, ${col.accent}55 100%);`} />
                <div class="card-header-content">
                  <div class="card-top-row">
                    <span class="company-name">{c.name}</span>
                  </div>
                  <span class="sec-code">東証 {c.secCode}</span>
                </div>
              </div>

              <div class="card-body">
                <div class="fiscal-badge">{c.period} 決算</div>

                <div class="metrics-mini">
                  <div class="metric-row">
                    <span class="metric-label">営業収益</span>
                    <span class="metric-value">{(c.revenue / 10000).toFixed(1)}兆円</span>
                  </div>
                  <div class="metric-row">
                    <span class="metric-label">営業利益</span>
                    <span class="metric-value">{c.operatingProfit.toLocaleString()}億円</span>
                  </div>
                </div>

                <div class="margin-bar-wrap">
                  <div class="margin-bar-label">
                    <span>利益率</span>
                    <span>{c.profitMargin.toFixed(1)}%</span>
                  </div>
                  <div class="margin-bar-track">
                    <div class="margin-bar-fill" style={`width: ${Math.min(c.profitMargin * 2, 100)}%`} />
                  </div>
                </div>

                <div class="card-footer">
                  <span class="stock-info">¥<strong>{c.stockPrice.toLocaleString()}</strong> (2/28終値)</span>
                  <a class="ir-link" href={c.irLink} target="_blank" rel="noopener">
                    IR ↗
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 2: 最新ニュース横スクロール ─── -->
  <section class="news-ticker-section" id="news">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">📰 最新ニュース & IRリリース</h2>
        <span class="section-count">自動スクロール（ホバーで停止）</span>
      </div>
    </div>

    <div class="news-ticker-track" id="news-ticker-track">
      <!-- JSでレンダリング -->
    </div>

  </section>

  <!-- ─── SECTION 3: 最新決算サマリー ─── -->
  <section class="section" id="summary">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">📋 最新決算サマリー</h2>
        <span class="section-count">単位: 億円</span>
      </div>
      <hr class="section-divider" />

      <div class="table-wrap" style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>企業名</th>
              <th>決算期</th>
              <th>営業収益</th>
              <th>前期比</th>
              <th>営業利益</th>
              <th>利益率</th>
              <th>経常利益</th>
              <th>純利益</th>
              <th>ROE</th>
              <th>株価</th>
            </tr>
          </thead>
          <tbody>
            {companies.map((c) => {
              const col = COMPANY_COLORS[c.name] ?? { bg: "#555" };
              const mClass = c.profitMargin >= 20 ? "margin-high" : c.profitMargin >= 15 ? "margin-mid" : "margin-low";
              const yoyClass = c.yoyGrowth >= 0 ? "yoy-positive" : "yoy-negative";
              return (
                <tr>
                  <td>
                    <div class="company-label">
                      <div class="company-dot" style={`background:${col.accent ?? col.bg}`} />
                      {c.name}
                    </div>
                  </td>
                  <td>{c.period}</td>
                  <td>{c.revenue.toLocaleString()}</td>
                  <td><span class={`yoy-growth ${yoyClass}`}>{c.yoyGrowth > 0 ? '+' : ''}{c.yoyGrowth.toFixed(1)}%</span></td>
                  <td>{c.operatingProfit.toLocaleString()}</td>
                  <td><span class={`margin-pill ${mClass}`}>{c.profitMargin.toFixed(1)}%</span></td>
                  <td>{c.ordinaryProfit.toLocaleString()}</td>
                  <td>{c.netProfit.toLocaleString()}</td>
                  <td>{c.roe.toFixed(1)}%</td>
                  <td>¥{c.stockPrice.toLocaleString()}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 4: 再開発プロジェクト ─── -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">🏗️ 再開発プロジェクト</h2>
        <span class="section-count">{projects.length} 件</span>
      </div>
      <hr class="section-divider" />

      <div class="table-wrap" style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>企業名</th>
              <th style="text-align:left;">プロジェクト名</th>
              <th>エリア</th>
              <th>規模</th>
              <th>完成予定</th>
              <th>状況</th>
            </tr>
          </thead>
          <tbody>
            {projects.map((p) => {
              const statusMap = {
                "進行中": "status-active",
                "着工済": "status-started",
                "計画中": "status-plan",
                "完成": "status-complete"
              };
              const col = COMPANY_COLORS[p.company] ?? { bg: "#555" };
              return (
                <tr>
                  <td>
                    <div class="company-label">
                      <div class="company-dot" style={`background:${col.accent ?? col.bg}`} />
                      {p.company}
                    </div>
                  </td>
                  <td style="text-align:left;">{p.name}</td>
                  <td>{p.location}</td>
                  <td>{p.scale}</td>
                  <td>{p.year}年</td>
                  <td>
                    <span class={`project-status ${statusMap[p.status] ?? "status-plan"}`}>
                      {p.status}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

