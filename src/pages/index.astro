<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>大手不動産デベロッパー IR ダッシュボード | deveryman-ir</title>
  <meta name="description" content="三井不動産・三菱地所などの最新決算・再開発情報をまとめて確認" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Inter:wght@400;600;800&display=swap" rel="stylesheet" />

  <style is:global>
    /* === RESET & BASE === */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Sans JP', sans-serif;
      background: #0a0f1e;
      color: #e8eaf0;
      min-height: 100vh;
      line-height: 1.6;
    }
    a { color: inherit; text-decoration: none; }

    /* === LAYOUT === */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

    /* === HEADER === */
    .header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10, 15, 30, 0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08); padding: 16px 0;
    }
    .header-inner { display: flex; align-items: center; justify-content: space-between; }
    .logo { font-size: 1.25rem; font-weight: 900; background: linear-gradient(90deg, #60a5fa, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.02em; }
    .logo span { font-weight: 400; opacity: 0.7; }
    
    .nav { display: flex; gap: 24px; }
    .nav a { font-size: 0.85rem; font-weight: 500; color: rgba(255, 255, 255, 0.6); transition: color 0.2s; }
    .nav a:hover { color: #fff; }
    
    .header-actions { display: flex; align-items: center; gap: 12px; }
    .badge-updated { font-size: 0.75rem; background: rgba(96, 165, 250, 0.15); border: 1px solid rgba(96, 165, 250, 0.3); color: #93c5fd; padding: 4px 12px; border-radius: 20px; white-space: nowrap; }
    .twitter-link { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); color: #e8eaf0; transition: all 0.2s; }
    .twitter-link:hover { background: rgba(255, 255, 255, 0.15); color: #fff; transform: translateY(-2px); }

    /* === AD BANNER SLOTS === */
    .ad-banner { width: 100%; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .ad-banner-header { background: rgba(255, 255, 255, 0.03); border-bottom: 1px solid rgba(255, 255, 255, 0.06); min-height: 90px; padding: 8px 0; }
    .ad-banner-footer { background: rgba(255, 255, 255, 0.03); border-top: 1px solid rgba(255, 255, 255, 0.06); border-bottom: 1px solid rgba(255, 255, 255, 0.06); min-height: 90px; padding: 8px 0; }
    .ad-placeholder { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; max-width: 728px; height: 90px; border: 1px dashed rgba(255, 255, 255, 0.1); border-radius: 8px; color: rgba(255, 255, 255, 0.15); font-size: 0.72rem; letter-spacing: 0.05em; user-select: none; }
    .ad-placeholder-icon { font-size: 1rem; opacity: 0.4; }

    /* === HERO === */
    .hero { padding: 40px 0 24px; text-align: center; background: radial-gradient(ellipse at 50% -20%, rgba(96, 165, 250, 0.12) 0%, transparent 70%); }
    .hero-eyebrow { font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; color: #60a5fa; margin-bottom: 12px; }
    .hero-title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 900; margin-bottom: 12px; line-height: 1.2; }
    .hero-title em { font-style: normal; background: linear-gradient(90deg, #60a5fa, #a78bfa, #f472b6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .hero-sub { font-size: 0.88rem; color: rgba(255, 255, 255, 0.5); max-width: 480px; margin: 0 auto; }

    /* === SECTION COMMON === */
    .section { padding: 32px 0; }
    .section-header { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 18px; flex-wrap: wrap; }
    .section-title-wrap { display: flex; align-items: baseline; gap: 12px; }
    .section-title { font-size: 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 8px; }
    .section-count { font-size: 0.75rem; color: rgba(255, 255, 255, 0.4); }

    /* === FILTER BUTTONS === */
    .filter-group { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; padding-bottom: 2px; }
    .filter-group::-webkit-scrollbar { display: none; }
    .filter-btn { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); color: rgba(255, 255, 255, 0.6); padding: 6px 14px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.25s ease; }
    .filter-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }
    .filter-btn.active { background: linear-gradient(135deg, rgba(96, 165, 250, 0.3) 0%, rgba(167, 139, 250, 0.3) 100%); border-color: rgba(96, 165, 250, 0.5); color: #fff; box-shadow: 0 0 12px rgba(96, 165, 250, 0.15); }

    /* === COMPANY CARDS (COMPACT) === */
    .cards-row { display: flex; align-items: center; gap: 0; }
    .scroll-arrow { flex-shrink: 0; width: 44px; height: 44px; border: 1px solid rgba(255, 255, 255, 0.12); background: rgba(255, 255, 255, 0.05); color: rgba(255, 255, 255, 0.7); border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); z-index: 2;}
    .scroll-arrow:hover { background: rgba(255,255,255,0.1); color: #fff; border-color: rgba(96, 165, 250, 0.5); }
    .scroll-arrow svg { width: 20px; height: 20px; }

    .cards-scroll-wrapper { display: flex; gap: 16px; overflow-x: auto; padding: 10px 0 30px; scrollbar-width: none; flex: 1; scroll-behavior: smooth; }
    .cards-scroll-wrapper::-webkit-scrollbar { display: none; }

    .company-card { min-width: 240px; flex-shrink: 0; background: #161b30; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; overflow: hidden; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .company-card:hover { transform: translateY(-4px); border-color: rgba(255, 255, 255, 0.2); box-shadow: 0 16px 32px rgba(0,0,0,0.5); }
    
    .card-top-identity { padding: 12px 16px; color: #fff; }
    .company-header-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .logo-box { width: 28px; height: 28px; background: #fff; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .logo-fallback { font-weight: 900; font-size: 0.85rem; }
    .company-name { font-size: 1.15rem; font-weight: 900; line-height: 1; }
    .sec-code { font-size: 0.65rem; color: rgba(255, 255, 255, 0.6); font-family: 'Inter', sans-serif; font-weight: 600; margin-left: auto; }

    .hero-stats-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 8px; }
    .stat-label-colored { font-size: 0.6rem; color: rgba(255, 255, 255, 0.5); font-weight: 700; display: block; margin-bottom: 2px; }
    .stat-value-large { font-size: 1.25rem; font-weight: 800; font-family: 'Inter', sans-serif; }
    .unit-hero { font-size: 0.75rem; margin-left: 2px; color: rgba(255, 255, 255, 0.5); font-weight: 500; }

    .card-body { padding: 12px 16px; }
    .fiscal-badge { font-size: 0.6rem; color: #64748b; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; display: inline-block; background: rgba(255, 255, 255, 0.05); padding: 2px 8px; border-radius: 4px; }
    .metrics-grid-container { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px 6px; }
    .metric-group { display: flex; flex-direction: column; }
    .metric-title { font-size: 0.6rem; color: #94a3b8; margin-bottom: 2px; font-weight: 700; }
    .metric-title.valuation { color: #38bdf8; opacity: 0.8; }
    .metric-data { font-size: 0.95rem; font-weight: 800; font-family: 'Inter', sans-serif; white-space: nowrap; }
    .unit-small { font-size: 0.65rem; color: #475569; margin-left: 2px; }

    .card-footer { display: flex; justify-content: flex-end; align-items: center; padding-top: 12px; margin-top: 10px; border-top: 1px solid rgba(255,255,255,0.06); }
    .ir-link-btn { font-size: 0.6rem; font-weight: 700; color: #94a3b8; background: rgba(255,255,255,0.03); padding: 4px 8px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.08); transition: 0.2s; }
    .ir-link-btn:hover { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.2); }

    /* === NEWS TICKER === */
    .news-ticker-section { background: rgba(255, 255, 255, 0.02); border-top: 1px solid rgba(255, 255, 255, 0.08); border-bottom: 1px solid rgba(255, 255, 255, 0.08); padding: 24px 0; }
    .news-scroll-wrapper { height: 440px; overflow: hidden; position: relative; background: rgba(15, 23, 42, 0.5); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 16px; }
    .news-scroll-wrapper::before, .news-scroll-wrapper::after { content: ''; position: absolute; left: 0; right: 0; height: 48px; z-index: 2; pointer-events: none; }
    .news-scroll-wrapper::before { top: 0; background: linear-gradient(to bottom, rgba(15, 23, 42, 0.95), transparent); }
    .news-scroll-wrapper::after { bottom: 0; background: linear-gradient(to top, rgba(15, 23, 42, 0.95), transparent); }
    .news-ticker-track { display: flex; flex-direction: column; gap: 0; padding: 16px; }
    .news-ticker-track:hover { animation-play-state: paused !important; }
    @keyframes ticker-scroll-vertical { 0% { transform: translateY(0); } 100% { transform: translateY(-50%); } }
    .news-card { display: flex; align-items: center; gap: 10px; padding: 12px 20px; background: rgba(255, 255, 255, 0.03); border-bottom: 1px solid rgba(255, 255, 255, 0.05); cursor: pointer; transition: all 0.2s ease; flex-shrink: 0; text-decoration: none; color: inherit; white-space: nowrap; overflow: hidden; }
    .news-card:first-child { border-radius: 12px 12px 0 0; }
    .news-card:last-child { border-radius: 0 0 12px 12px; border-bottom: none; }
    .news-card:hover { background: rgba(255, 255, 255, 0.06); }
    .news-card-date { font-size: 0.75rem; color: rgba(255, 255, 255, 0.35); white-space: nowrap; font-variant-numeric: tabular-nums; flex-shrink: 0; width: 82px; min-width: 82px; }
    .news-category { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.06em; padding: 2px 8px; border-radius: 4px; white-space: nowrap; text-transform: uppercase; flex-shrink: 0; width: 28px; min-width: 28px; text-align: center; }
    .news-category.IR { background: rgba(96, 165, 250, 0.15); color: #93c5fd; }
    .news-category.PR { background: rgba(167, 139, 250, 0.15); color: #c4b5fd; }
    .news-card-company { font-size: 0.82rem; font-weight: 700; color: var(--accent-color, #93c5fd); white-space: nowrap; flex-shrink: 0; width: 110px; min-width: 110px; }
    .news-card-sep { color: rgba(255, 255, 255, 0.15); flex-shrink: 0; font-size: 0.75rem; }
    .news-card-title { font-size: 0.82rem; font-weight: 700; color: #e8eaf0; white-space: nowrap; flex-shrink: 0; }
    .news-card-desc { font-size: 0.78rem; color: rgba(255, 255, 255, 0.38); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
    .news-empty { padding: 60px 20px; text-align: center; color: rgba(255, 255, 255, 0.3); font-size: 0.85rem; }

    /* === SUMMARY TABLES (TIGHT/COLD LAYOUT) === */
    .summary-tables-grid { display: grid; grid-template-columns: minmax(0, 1fr); gap: 24px; margin-top: 20px; overflow-x: auto; padding-bottom: 10px; }
    @media (min-width: 1024px) { .summary-tables-grid { grid-template-columns: 1.4fr 1fr; align-items: start; overflow-x: visible; } }
    .table-meta { font-size: 0.85rem; font-weight: 700; margin-bottom: 10px; color: #93c5fd; display: flex; align-items: baseline; }
    .table-meta span { font-size: 0.65rem; color: rgba(255,255,255,0.4); margin-left: 8px; font-weight: 400; }

    .table-wrap { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; overflow: hidden; width: fit-content; }
    .data-table { border-collapse: collapse; width: auto; }
    .data-table th { background: rgba(255, 255, 255, 0.05); padding: 10px 14px; text-align: right; font-size: 0.7rem; color: rgba(255, 255, 255, 0.45); white-space: nowrap; }
    .data-table th:first-child { text-align: left; }
    .data-table td { padding: 12px 14px; text-align: right; font-size: 0.82rem; border-top: 1px solid rgba(255, 255, 255, 0.05); white-space: nowrap; }
    .data-table td:first-child { text-align: left; min-width: 110px; }
    .data-table tr:hover td { background: rgba(255,255,255,0.03); }

    .company-label { display: flex; align-items: center; gap: 8px; font-weight: 600; }
    .company-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .yoy-growth { font-size: 0.75rem; font-weight: 600; margin-left: 4px; font-family: 'Inter', sans-serif;}
    .yoy-positive { color: #34d399; }
    .yoy-negative { color: #f87171; }
    .margin-pill { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; font-family: 'Inter', sans-serif;}
    .margin-high { background: rgba(52, 211, 153, 0.15); color: #34d399; }
    .margin-mid { background: rgba(251, 191, 36, 0.15); color: #fbbf24; }
    .margin-low { background: rgba(239, 68, 68, 0.15); color: #f87171; }

    /* === PROJECT STATUS === */
    .project-status { display: inline-block; font-size: 0.7rem; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
    .status-active { background: rgba(52, 211, 153, 0.15); color: #34d399; }
    .status-plan { background: rgba(251, 191, 36, 0.15); color: #fbbf24; }
    .status-started { background: rgba(96, 165, 250, 0.15); color: #93c5fd; }
    .status-complete { background: rgba(148, 163, 184, 0.15); color: #94a3b8; }
    .project-row { cursor: pointer; transition: 0.2s; }
    .project-row:hover { background: rgba(255,255,255,0.04); }
    .project-row.is-hovered { background: rgba(99, 102, 241, 0.08); box-shadow: inset 3px 0 0 #6366f1; }

    /* === MAP === */
    .map-section { position: relative; height: 420px; background: #0f111a; border-radius: 16px; overflow: hidden; margin-top: 24px; border: 1px solid rgba(255,255,255,0.05); }
    .map-title-overlay { position: absolute; top: 16px; left: 16px; z-index: 20; background: rgba(28, 30, 43, 0.85); padding: 8px 14px; border-radius: 10px; font-size: 0.9rem; font-weight: 700; color: #fff; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);}
    
    /* Google Maps Pins */
    .map-pin { transition: all 0.3s ease; cursor: pointer; z-index: 10; opacity: 1; }
    .map-pin.is-dimmed { opacity: 0.25; transform: scale(0.85); }
    .map-pin.is-active { z-index: 30; }
    .map-pin-circle { position: relative; width: 16px; height: 16px; border-radius: 50%; border: 2px solid rgba(15, 17, 26, 0.9); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4); display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; }
    .map-pin.is-active .map-pin-circle { width: 22px; height: 22px; box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.15), 0 2px 12px rgba(0, 0, 0, 0.5); }
    .map-pin-dot { width: 5px; height: 5px; background: #fff; border-radius: 50%; display: none; }
    .map-pin.is-active .map-pin-dot { display: block; }
    .map-pin-ping { position: absolute; inset: -6px; border-radius: 50%; opacity: 0; animation: none; }
    .map-pin.is-active .map-pin-ping { opacity: 0.35; animation: map-ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite; }
    @keyframes map-ping { 0% { transform: scale(1); opacity: 0.35; } 75%, 100% { transform: scale(2.2); opacity: 0; } }
    .map-pin-tooltip { display: none; position: absolute; bottom: calc(100% + 10px); left: 50%; transform: translateX(-50%); background: rgba(28, 30, 43, 0.95); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 10px; padding: 10px 14px; white-space: nowrap; pointer-events: none; z-index: 30; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5); }
    .map-pin.is-active .map-pin-tooltip { display: block; }
    .map-pin-tooltip-company { font-size: 0.72rem; font-weight: 700; margin-bottom: 2px; }
    .map-pin-tooltip-name { font-size: 0.7rem; font-weight: 500; color: rgba(255, 255, 255, 0.7); }

    /* === FOOTER === */
    .footer { border-top: 1px solid rgba(255, 255, 255, 0.06); padding: 28px 0; margin-top: 40px; }
    .footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .footer-text { font-size: 0.75rem; color: rgba(255, 255, 255, 0.3); }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 0.75rem; color: rgba(255, 255, 255, 0.3); }
    .footer-links a:hover { color: rgba(255, 255, 255, 0.6); }

    @media (max-width: 768px) {
      .nav { display: none; }
      .hero-title { font-size: 1.6rem; }
      .company-card { min-width: 220px; }
      .data-table { font-size: 0.7rem; }
      .summary-tables-grid { gap: 16px; }
      .table-wrap { width: 100%; }
      .data-table { width: 100%; }
      .section-header { flex-direction: column; align-items: flex-start; gap: 12px; }
      .filter-group { align-self: stretch; }
      .news-card { padding: 10px 14px; gap: 6px; }
      .news-card-company { font-size: 0.75rem; }
      .news-card-title { font-size: 0.75rem; }
      .news-card-desc { font-size: 0.7rem; }
      .news-scroll-wrapper { height: 380px; }
      .ad-placeholder { max-width: 320px; height: 50px; }
      .ad-banner-header, .ad-banner-footer { min-height: 50px; }
      .ad-banner img { max-height: 50px; }
      .map-section { height: 300px; }
      .map-pin-tooltip { display: none !important; }
    }
  </style>
</head>

<body>

  <!-- HEADER -->
