  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans", "Noto Sans JP", sans-serif; background: #0a0a0f; color: #ccc; line-height: 1.85; }
    .container { max-width: 780px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
    h1 { font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 0.25rem; }
    .updated { font-size: 0.78rem; color: rgba(255,255,255,0.3); margin-bottom: 2.5rem; }
    section { margin-bottom: 2.5rem; }
    h2 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 1rem; padding-bottom: 0.4rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    h3 { font-size: 0.92rem; font-weight: 600; color: #e8e8e8; margin-top: 1.25rem; margin-bottom: 0.5rem; }
    p { font-size: 0.85rem; margin-bottom: 0.75rem; }
